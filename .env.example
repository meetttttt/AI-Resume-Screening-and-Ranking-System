# Copy to .env.local and fill in real values:
#   cp .env.example .env.local

# OpenAI — required for resume analysis
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Supabase — required for sign-in and saving screenings
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Use either the anon (legacy JWT) or publishable key — not the service_role key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: newer Supabase projects may use this instead of NEXT_PUBLIC_SUPABASE_ANON_KEY
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Optional: app base URL (e.g. for auth redirects in production). Not read by all code paths yet.
# NEXT_PUBLIC_APP_URL=http://localhost:3000
